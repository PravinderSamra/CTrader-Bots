{
  "mcpServers": {
    "tradingview-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["tradingview-mcp"]
    },
    "coingecko": {
      "type": "http",
      "url": "https://mcp.api.coingecko.com/mcp"
    },
    "pinescript-docs": {
      "type": "stdio",
      "command": "uvx",
      "args": ["pinescript-mcp"]
    },
    "alpha-vantage": {
      "type": "stdio",
      "command": "uvx",
      "args": ["marketdata-mcp-server", "YOUR_API_KEY"],
      "_comment": "Get a free API key at https://www.alphavantage.co/support/#api-key then replace YOUR_API_KEY"
    }
  }
}
